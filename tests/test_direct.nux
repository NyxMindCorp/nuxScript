struct User
    name   :: String
    age    :: Int
    active :: Bool
end

let users = [
    User(name: "Fernanda", age: 25, active: true),
    User(name: "Carlos", age: 30, active: false),
    User(name: "Ana", age: 28, active: true)
]

let active = filter(users, (u) => u.active == true)
print(active.length)